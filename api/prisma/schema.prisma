// Auctra API data model.
//
// The chain is the source of truth. Everything in this database is a *cache*
// of on-chain state plus the API-only concepts the chain has no opinion about:
// API keys, idempotency records, webhook endpoints and delivery attempts.
//
// Postgres only. Do not swap in SQLite: the idempotency table relies on
// transactional upserts under concurrent writers, and the indexer relies on
// SELECT ... FOR UPDATE SKIP LOCKED for the webhook queue.

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Environment {
  sandbox
  production
}

enum AuctionStatus {
  pending // tx broadcast, not yet confirmed
  live // accepting bids
  ending // in the anti-snipe extension window
  ended // clock expired, not yet settled on chain
  settled // endAuction() confirmed, proceeds credited
  cancelled // seller cancelled before first bid
}

enum BidStatus {
  pending
  confirmed
  outbid
  winning
  won
  failed
}

enum DeliveryStatus {
  pending
  succeeded
  failed
  exhausted
}

model Organization {
  id        String      @id @default(cuid())
  name      String
  env       Environment
  createdAt DateTime    @default(now())

  apiKeys          ApiKey[]
  auctions         Auction[]
  webhookEndpoints WebhookEndpoint[]
  events           Event[]
  idempotencyKeys  IdempotencyKey[]

  @@map("organizations")
}

model ApiKey {
  id     String @id @default(cuid())
  orgId  String
  org    Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  // Displayed once at creation, then discarded. We persist only the hash.
  hash       String   @unique
  prefix     String // "sk_test_a1b2" — safe to show in dashboards and logs
  label      String
  scopes     String[] @default(["auctions:read", "auctions:write"])
  lastUsedAt DateTime?
  revokedAt  DateTime?
  createdAt  DateTime @default(now())

  @@index([orgId])
  @@map("api_keys")
}

model Auction {
  id    String @id @default(cuid()) // "auc_..." exposed id lives in `ref`
  ref   String @unique // public id, e.g. auc_3f9a2c
  orgId String
  org   Organization @relation(fields: [orgId], references: [id])

  // On-chain identity
  chainId       Int
  contract      String // AuctionHouse address
  onchainId     BigInt? // AuctionHouse auction id, null until confirmed
  createTxHash  String?
  settleTxHash  String?

  seller        String
  tokenContract String
  tokenId       BigInt

  reservePriceWei String // stringified wei — never a JS number
  minIncrementBps Int    @default(500) // 5%
  startTime       DateTime
  endTime         DateTime
  extensionWindow Int    @default(300) // seconds
  extensionCount  Int    @default(0)
  maxExtensions   Int    @default(10)

  highestBidWei    String @default("0")
  highestBidder    String?
  status           AuctionStatus @default(pending)
  metadata         Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  bids    Bid[]
  refunds Refund[]

  @@unique([chainId, contract, onchainId])
  @@index([orgId, status])
  @@index([seller])
  @@map("auctions")
}

model Bid {
  id        String @id @default(cuid())
  ref       String @unique // bid_...
  auctionId String
  auction   Auction @relation(fields: [auctionId], references: [id], onDelete: Cascade)

  bidder    String
  amountWei String
  status    BidStatus @default(pending)

  txHash      String?
  blockNumber BigInt?
  logIndex    Int?
  placedAt    DateTime @default(now())

  @@unique([txHash, logIndex])
  @@index([auctionId, amountWei])
  @@index([bidder])
  @@map("bids")
}

// Pull-payment credits. The contract never pushes ETH to an outbid bidder;
// it credits them and they withdraw. We mirror that balance for reads.
model Refund {
  id        String @id @default(cuid())
  ref       String @unique // ref_...
  auctionId String?
  auction   Auction? @relation(fields: [auctionId], references: [id])

  chainId    Int
  contract   String
  bidder     String
  amountWei  String
  withdrawn  Boolean @default(false)
  withdrawTx String?
  createdAt  DateTime @default(now())

  @@index([bidder, withdrawn])
  @@map("refunds")
}

model Event {
  id        String @id @default(cuid())
  ref       String @unique // evt_...
  orgId     String
  org       Organization @relation(fields: [orgId], references: [id])

  type       String // auction.bid_placed
  objectRef  String // auc_3f9a2c
  payload    Json
  chainBlock BigInt?
  createdAt  DateTime @default(now())

  deliveries WebhookDelivery[]

  @@index([orgId, type, createdAt])
  @@map("events")
}

model WebhookEndpoint {
  id    String @id @default(cuid())
  ref   String @unique // whe_...
  orgId String
  org   Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  url           String
  secret        String // whsec_...
  enabledEvents String[]
  disabledAt    DateTime?
  createdAt     DateTime @default(now())

  deliveries WebhookDelivery[]

  @@index([orgId])
  @@map("webhook_endpoints")
}

model WebhookDelivery {
  id         String @id @default(cuid())
  endpointId String
  endpoint   WebhookEndpoint @relation(fields: [endpointId], references: [id], onDelete: Cascade)
  eventId    String
  event      Event @relation(fields: [eventId], references: [id], onDelete: Cascade)

  status       DeliveryStatus @default(pending)
  attempt      Int      @default(0)
  nextAttemptAt DateTime @default(now())
  responseCode Int?
  responseBody String?
  createdAt    DateTime @default(now())

  @@unique([endpointId, eventId])
  @@index([status, nextAttemptAt])
  @@map("webhook_deliveries")
}

// A replayed POST with the same Idempotency-Key returns the stored response
// verbatim — including the original status code — for 24 hours.
model IdempotencyKey {
  id    String @id @default(cuid())
  orgId String
  org   Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  key          String
  method       String
  path         String
  requestHash  String // sha256 of the body; a mismatch is a 409
  statusCode   Int?
  responseBody Json?
  lockedAt     DateTime @default(now())
  completedAt  DateTime?
  expiresAt    DateTime

  @@unique([orgId, key])
  @@index([expiresAt])
  @@map("idempotency_keys")
}

model IndexerCursor {
  id          String @id @default(cuid())
  chainId     Int
  contract    String
  lastBlock   BigInt
  updatedAt   DateTime @updatedAt

  @@unique([chainId, contract])
  @@map("indexer_cursors")
}
